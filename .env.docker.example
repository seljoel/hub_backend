# Database (Natively running on your host machine)
DATABASE_URL=postgresql+asyncpg://cixiohub:cixiohub@host.docker.internal:5432/cixiohub

# Application
APP_NAME="CixioHub API (Docker App Only)"
DEBUG=True

# Redis (Natively running on your host machine)
REDIS_URL=redis://host.docker.internal:6379/0

# JWT Authentication Config
SECRET_KEY=dev_secret_key_for_cixiohub_backend_token_signing_12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Ollama (Natively running on your host machine)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=qwen3-vl:2b
ENABLE_VISION_RAG=True

# AI Service (Natively running on your host machine)
AI_SERVICE_URL=http://host.docker.internal:8003

# Qdrant Vector Database (Natively running on your host machine)
QDRANT_URL=http://host.docker.internal:6333
QDRANT_COLLECTION=user_documents

# RabbitMQ Message Broker (Natively running on your host machine)
RABBITMQ_URL=amqp://guest:guest@host.docker.internal:5672/

# SMTP / Email (Natively running on your host machine)
SMTP_HOST=host.docker.internal
SMTP_PORT=1025
SMTP_FROM_EMAIL=noreply@hub.cixio.dev

# File upload limits
MAX_UPLOAD_SIZE_MB=50

# Google OAuth (Optional credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Local Test Configuration User
TEST_EMAIL=test@tkmce.ac.in
TEST_PASSWORD=your_test_password
TEST_NAME="Test User"
TEST_PHONE=0000000000
